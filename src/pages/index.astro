---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date) => {
  const d = new Date(date);
  return d.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
};
---

<BaseLayout title="Project-that" description="Slow writing on the ground of experience of Advaita Vedanta.">
  <div class="hero-image-wrap">
    <img
      src="/images/hero.png"
      alt="Vast mountain range in muted tones"
      class="hero-image"
    />
  </div>

  <div class="container">
    <section class="hero">
      <h1>Notes on what was <em>always already</em> the case.</h1>
      <p>Slow writing on the ground of experience of Advaita Vedanta — drawing from the Ashtavakra Gita, Ribhu Gita, Tripura Rahasya, Ramana Maharshi, and the teachings of Amrutananda Saraswati.</p>
      <p class="invocation">॥ श्री मात्रे नमः ॥ &nbsp; ॥ श्री गुरुभ्यो नमः ॥</p>
    </section>

    <section class="post-list">
    <div class="post-list-heading">Recent Writings</div>

    {posts.length === 0 && (
      <p style="color: var(--ink-soft); font-style: italic; padding: 24px 0;">
        First post coming soon.
      </p>
    )}

    {posts.map((post) => (
      <a href={`/blog/${post.id}/`} class="post-item">
        <div>
          <div class="post-item-date">{formatDate(post.data.date)}</div>
          {post.data.category && (
            <div class="post-item-category">{post.data.category}</div>
          )}
        </div>
        <div>
          <div class="post-title">{post.data.title}</div>
          {post.data.subtitle && (
            <div class="post-subtitle">{post.data.subtitle}</div>
          )}
        </div>
      </a>
    ))}
    </section>
  </div>
</BaseLayout>
